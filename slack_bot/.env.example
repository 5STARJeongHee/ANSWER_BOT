# Slack 봇 전체 환경변수 템플릿 - 실제 값으로 채워서 .env로 사용
# 주의: .env 파일은 절대 git에 커밋하지 말 것

# -- Slack 토큰 (Slack App 설정 페이지에서 발급) --
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# -- OpenRouter API Key --
OPENROUTER_API_KEY=your-openrouter-api-key-here

# -- Supabase 데이터베이스 설정 --
# Transaction Pooler (포트 6543) - 일반 쿼리에 권장
# Supabase 대시보드 -> Project Settings -> Database -> Connection string (Transaction)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Direct Connection (포트 5432) - 마이그레이션(psql) 실행 시에만 사용
# DATABASE_URL_DIRECT=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Supabase 프로젝트 정보 (REST API / Realtime 사용 시 필요)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -- pgvector 설정 --
# Supabase는 pgvector가 기본 내장 - 별도 설치 불필요
ENABLE_VECTOR_SEARCH=true
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768
RAG_TOP_K=5

# -- 모델 설정 파일 경로 --
MODEL_CONFIG_PATH=../properties.yml

# -- LLM 백엔드 선택 --
# "openrouter": OpenRouter API 사용 (기본값, OPENROUTER_API_KEY 필요)
# "ollama":     로컬 Ollama 서버 사용 (API 키 불필요)
LLM_BACKEND=openrouter

# -- OpenRouter 설정 (LLM_BACKEND=openrouter) --
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MAX_CONTEXT_TOKENS=6000
MAX_RETRIES=3

# -- Ollama 설정 (LLM_BACKEND=ollama) --
# Docker Compose로 함께 실행: http://ollama:11434/v1
# 호스트에서 직접 실행: http://localhost:11434/v1
OLLAMA_BASE_URL=http://ollama:11434/v1
# CPU 추론은 70B 모델 기준 응답에 수십 초 소요 - 기본 120초 권장
LLM_TIMEOUT=120.0

# -- Slack 채널 및 담당자 설정 --
# 채널 ID: Slack에서 채널 우클릭 -> 링크 복사 URL 맨 끝 C로 시작하는 값
TARGET_CHANNEL_IDS=C0123456789,C9876543210
FALLBACK_MENTION_USER_IDS=U0123456789

# -- 배치 스케줄 설정 --
SUMMARY_BATCH_HOUR=2
SUMMARY_BATCH_WEEKDAY=0

# -- RAG 및 임베딩 설정 --
# RAG 검색 최종 반환 K개 (Reranking 활성 시 RAG_RERANK_POOL_K 후보에서 상위 K개 반환)
RAG_TOP_K=3
# RAG 청크 1개당 최대 문자 수 (SQL DDL, 에러 로그 등 긴 텍스트 고려)
RAG_CHUNK_MAX_CHARS=500
# 최근 대화 포함 메시지 수 (다자 대화 컨텍스트 보존)
RECENT_MESSAGE_COUNT=8
# 임베딩 최소 문자 수 — 이보다 짧은 단답(넵, 감사합니다 등)은 RAG 노이즈 방지를 위해 임베딩 생략
EMBED_MIN_CHARS=15

# -- Advanced RAG 설정 --
# Hybrid Search: pg_trgm(키워드) + pgvector(의미) 결합 (에러코드·한글 모두 지원)
ENABLE_HYBRID_SEARCH=true
# Reranking: Cross-Encoder로 후보 재정렬 (정밀도 향상)
ENABLE_RERANKING=true
# Reranker 모델 (fastembed TextCrossEncoder — multilingual)
RERANK_MODEL=BAAI/bge-reranker-base
# Reranker에 전달할 초기 후보 수 (이 수를 검색 후 RAG_TOP_K개로 재정렬)
RAG_RERANK_POOL_K=15
# Thread 청킹: 스레드 내 Q&A 흐름을 하나의 통합 청크로 임베딩
ENABLE_THREAD_CHUNKING=true
# Thread 청크 최대 문자 수 (Q&A 흐름 보존)
THREAD_CHUNK_MAX_CHARS=1500

# -- 웹 검색 설정 --
# 이미지 첨부 또는 에러 로그 질문 시 DuckDuckGo로 관련 정보 검색 (API 키 불필요)
ENABLE_WEB_SEARCH=true
WEB_SEARCH_TOP_K=3
WEB_SEARCH_TIMEOUT=4.0
WEB_SEARCH_MAX_CHARS=200

# -- 로그 및 디버그 --
LOG_LEVEL=INFO
DEBUG=false
