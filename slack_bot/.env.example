# Slack 봇 전체 환경변수 템플릿 - 실제 값으로 채워서 .env로 사용
# 주의: .env 파일은 절대 git에 커밋하지 말 것

# Slack 토큰 (Slack App 설정 페이지에서 발급)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# OpenRouter API Key
OPENROUTER_API_KEY=your-openrouter-api-key-here

# PostgreSQL 연결 문자열
DATABASE_URL=postgresql://slackbot:slackbot_password@localhost:5432/slackbot_db

# 벡터 검색 활성화 여부 (pgvector 없는 환경에서는 false)
ENABLE_VECTOR_SEARCH=true

# 임베딩 모델 (sentence-transformers)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768

# 모델 설정 파일 경로 (properties.txt)
MODEL_CONFIG_PATH=../properties.txt

# LLM 설정
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MAX_CONTEXT_TOKENS=6000
MAX_RETRIES=3

# 수집 대상 Slack 채널 ID (쉼표 구분)
# 채널 ID는 Slack에서 채널 우클릭 → 링크 복사 URL에서 확인
TARGET_CHANNEL_IDS=C0123456789,C9876543210

# Fallback 담당자 Slack User ID (쉼표 구분)
FALLBACK_MENTION_USER_IDS=U0123456789

# 배치 스케줄 설정 (주간 요약)
SUMMARY_BATCH_HOUR=2
SUMMARY_BATCH_WEEKDAY=0

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 개발 환경 여부
DEBUG=false
